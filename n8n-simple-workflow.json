{
  "name": "NexGen Gemini Chat",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "chat"
      },
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 250]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "message",
              "value": "={{ $json.body.message }}"
            },
            {
              "name": "session_id",
              "value": "={{ $json.body.session_id }}"
            }
          ]
        }
      },
      "id": "2",
      "name": "Extract Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [450, 250]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
        "sendHeaders": true,
        "headers": {
          "x-goog-api-key": "{{ $env.GEMINI_API_KEY }}"
        },
        "sendBody": true,
        "bodyParametersJson": "={{ JSON.stringify({ contents: [{ parts: [{ text: $json.message }] }], generationConfig: { maxOutputTokens: 500 } }) }}"
      },
      "id": "3",
      "name": "Call Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [650, 250]
    },
    {
      "parameters": {
        "jsCode": "let response = 'Error';\nif ($json.body?.candidates?.[0]?.content?.parts?.[0]?.text) {\n  response = $json.body.candidates[0].content.parts[0].text;\n}\nreturn { response: response };"
      },
      "id": "4",
      "name": "Parse Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 250]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WORDPRESS_URL }}/wp-json/nexgen/v1/save-message",
        "sendHeaders": true,
        "headers": {
          "Authorization": "Bearer {{ $env.WORDPRESS_API_KEY }}"
        },
        "sendBody": true,
        "bodyParametersJson": "={{ JSON.stringify({ session_id: $json.session_id, message_text: $json.response, message_type: 'bot' }) }}"
      },
      "id": "5",
      "name": "Save to WP",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1050, 250]
    },
    {
      "parameters": {},
      "id": "6",
      "name": "Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1250, 250]
    }
  ],
  "connections": {
    "1": { "main": [[{ "node": "2", "type": "main", "index": 0 }]] },
    "2": { "main": [[{ "node": "3", "type": "main", "index": 0 }]] },
    "3": { "main": [[{ "node": "4", "type": "main", "index": 0 }]] },
    "4": { "main": [[{ "node": "5", "type": "main", "index": 0 }]] },
    "5": { "main": [[{ "node": "6", "type": "main", "index": 0 }]] }
  },
  "settings": {}
}
